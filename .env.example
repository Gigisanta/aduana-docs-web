# Demo works without these values. Set them to enable the production backend.

# PostgreSQL / Prisma
DATABASE_URL=

# Auth.js / NextAuth v5
AUTH_SECRET=
AUTH_URL=

# Cloudflare R2 / S3-compatible private document storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aduanadocs-documents
R2_PUBLIC_BASE_URL=

# Optional outbound email
RESEND_API_KEY=
